# EduLink Docker 환경 변수 제공 예제
# .env 파일로 복사하여 실제 값을 설정하세요

# Flask 환경
FLASK_ENV=production

# 보안 키 (프로덕션에서는 안전한 값으로 변경)
SECRET_KEY=super-secret-key-change-in-production

# 비밀번호 리셋 토큰 응답 노출 (기본값: false)
# 로컬 디버깅 시에만 true로 설정
EXPOSE_RESET_TOKEN_IN_RESPONSE=false

# 이메일 어댑터 선택 (기본값: mock)
# 옵션: mock (로컬), sendgrid (프로덕션), aws-ses (프로덕션)
EMAIL_ADAPTER_TYPE=mock

# SendGrid 설정 (EMAIL_ADAPTER_TYPE=sendgrid 일 때만 필수)
# https://sendgrid.com 에서 API 키 생성
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@edulink.com

# AWS SES 설정 (EMAIL_ADAPTER_TYPE=aws-ses 일 때만 필수)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=noreply@edulink.com

# PostgreSQL 설정
POSTGRES_DB=edulink_db
POSTGRES_USER=edulink_user
POSTGRES_PASSWORD=change-in-production

# Grafana 설정 (모니터링)
GRAFANA_PASSWORD=admin-change-in-production

# 데이터베이스 URL (선택사항, 필요한 경우)
# DATABASE_URL=postgresql://edulink_user:change-in-production@db:5432/edulink_db
