{
  "name": "edulink-e2e",
  "version": "1.0.0",
  "description": "EduLink E2E tests with Playwright",
  "scripts": {
    "configure:public": "node scripts/configure-public-site.mjs",
    "build": "node scripts/build-static.mjs",
    "validate:public": "node scripts/validate-public-site.mjs",
    "validate:public:strict": "node scripts/validate-public-site.mjs --strict",
    "build:release": "npm run build && npm run validate:public:strict",
    "release:public": "npm run build:release && npm run cf:deploy",
    "rc:lock": "powershell -ExecutionPolicy Bypass -File scripts/prepare-rc-lock.ps1 -RcVersion v2.0.0-rc1",
    "e2e:archive": "powershell -ExecutionPolicy Bypass -File scripts/archive-one-shot-evidence.ps1",
    "cf:deploy": "npm run build && npx wrangler deploy",
    "cf:deploy:dry": "npm run build && npx wrangler deploy --dry-run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "wrangler": "^4.76.0"
  }
}
